# ==========================================
# NSMPI - National Student Mental Performance Initiative
# Environment Configuration Template
# ==========================================

# ------------------------------------------
# Database Configuration
# ------------------------------------------
DB_USER=nsmpi
DB_PASSWORD=nsmpi_secure_password_2024
DB_NAME=nsmpi_db
DB_PORT=5432
DATABASE_URL=postgresql://nsmpi:nsmpi_secure_password_2024@localhost:5432/nsmpi_db?schema=public

# ------------------------------------------
# Redis Configuration
# ------------------------------------------
REDIS_PASSWORD=redis_secure_password_2024
REDIS_PORT=6379
REDIS_URL=redis://:redis_secure_password_2024@localhost:6379

# ------------------------------------------
# Server Configuration
# ------------------------------------------
NODE_ENV=development
PORT=5000
BACKEND_PORT=5000
FRONTEND_PORT=3000

# ------------------------------------------
# JWT Authentication
# ------------------------------------------
JWT_SECRET=your-super-secret-jwt-key-min-32-characters-long
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=your-refresh-secret-key-min-32-characters-long
JWT_REFRESH_EXPIRES_IN=30d

# ------------------------------------------
# Encryption
# ------------------------------------------
ENCRYPTION_KEY=your-32-char-encryption-key

# ------------------------------------------
# Feature Flags (Enable/Disable Modules)
# ------------------------------------------
# Core Features
FEATURE_SCREENING=true
FEATURE_THERAPIST_BOOKING=true
FEATURE_NATIONAL_DASHBOARD=true
FEATURE_SUBSIDY_ENGINE=true

# Advanced Features (Future Phases)
FEATURE_AI_ML=false
FEATURE_MOBILE_APP=false
FEATURE_ADVANCED_ANALYTICS=false

# ------------------------------------------
# Frontend Configuration
# ------------------------------------------
VITE_API_URL=http://localhost:5000/api
VITE_SOCKET_URL=http://localhost:5000
VITE_ENABLE_PWA=true

# ------------------------------------------
# Email Configuration (Optional - for notifications)
# ------------------------------------------
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
FROM_EMAIL=noreply@nsmpi.gov

# ------------------------------------------
# Logging
# ------------------------------------------
LOG_LEVEL=info
LOG_FILE=logs/app.log

# ------------------------------------------
# Rate Limiting
# ------------------------------------------
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
