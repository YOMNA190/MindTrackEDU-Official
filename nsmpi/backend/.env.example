# ─── Database ────────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/mindtrackedu?sslmode=require"

# ─── Security (generate with: openssl rand -base64 48) ───────────────────────
JWT_SECRET="replace-with-64-char-random-string"
ENCRYPTION_KEY="replace-with-strong-random-passphrase"

# ─── Server ───────────────────────────────────────────────────────────────────
PORT=4000
NODE_ENV=production

# ─── CORS ─────────────────────────────────────────────────────────────────────
FRONTEND_URL="https://your-project.vercel.app"
