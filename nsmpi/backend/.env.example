# ==========================================
# NSMPI - National Student Mental Performance Initiative
# Backend Environment Variables
# ==========================================

# Server Configuration
PORT=5000
NODE_ENV=development

# Database Configuration (PostgreSQL)
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL="postgresql://postgres:postgres_password@localhost:5432/nsmpi_db?schema=public"

# Redis Configuration (For BullMQ & Caching)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# Security & Authentication
JWT_SECRET="your_very_long_random_jwt_secret_here"
JWT_EXPIRES_IN=7d

# Encryption (AES-256 & RSA)
ENCRYPTION_KEY="32_character_long_aes_secret_key_here"

# CORS Configuration
CLIENT_URL="http://localhost:5173"

# Logging
LOG_LEVEL=info
LOG_FILE_PATH=logs/app.log

# Feature Flags
ENABLE_AUDIT_LOG=true
ENABLE_NOTIFICATIONS=true
