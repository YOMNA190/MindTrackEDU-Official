generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  STUDENT
  THERAPIST
  ADMIN
}

enum RiskLevel {
  LOW
  MODERATE
  HIGH
  SEVERE
}

enum PrimaryIssue {
  ANXIETY
  DEPRESSION
  FOCUS
  STRESS
  OTHER
}

model User {
  id           String      @id @default(cuid())
  email        String      @unique
  name         String
  passwordHash String
  role         Role
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  screenings   Screening[]
  chatSessionsAsStudent   ChatSession[] @relation("StudentSessions")
  chatSessionsAsTherapist ChatSession[] @relation("TherapistSessions")
}

model Screening {
  id                   String       @id @default(cuid())
  studentId            String
  student              User         @relation(fields: [studentId], references: [id])
  phq9Score            Int
  gad7Score            Int
  focusScore           Int
  totalScore           Int
  riskLevel            RiskLevel
  primaryIssue         PrimaryIssue
  academicImpactScore  Float
  explanationEn        String
  explanationAr        String
  qualifiesForSubsidy  Boolean      @default(false)
  createdAt            DateTime     @default(now())

  @@index([studentId])
  @@index([riskLevel])
}

model ChatSession {
  id                  String        @id @default(cuid())
  studentId           String
  therapistId         String
  student             User          @relation("StudentSessions",   fields: [studentId],   references: [id])
  therapist           User          @relation("TherapistSessions", fields: [therapistId], references: [id])
  status              SessionStatus @default(PENDING)
  encryptionPublicKey String
  lastMessageAt       DateTime?
  createdAt           DateTime      @default(now())
  messages            ChatMessage[]

  @@index([studentId])
  @@index([therapistId])
}

enum SessionStatus {
  PENDING
  ACTIVE
  ARCHIVED
}

enum MessageType {
  TEXT
  FILE
  IMAGE
  VIDEO_CALL_INVITE
}

model ChatMessage {
  id         String      @id @default(cuid())
  sessionId  String
  session    ChatSession @relation(fields: [sessionId], references: [id])
  senderId   String
  receiverId String
  content    String      // AES-256-GCM encrypted
  type       MessageType @default(TEXT)
  isRead     Boolean     @default(false)
  createdAt  DateTime    @default(now())

  @@index([sessionId])
  @@index([senderId])
}
