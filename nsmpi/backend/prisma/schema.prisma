// ==========================================
// MindTrackEDU - Simplified Schema
// ==========================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ==========================================
// Enums
// ==========================================

enum UserRole {
  STUDENT
  THERAPIST
  ADMIN
}

enum RiskLevel {
  LOW
  MODERATE
  HIGH
  SEVERE
}

enum SessionStatus {
  SCHEDULED
  COMPLETED
  CANCELLED
}

// ==========================================
// Core Models
// ==========================================

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  role      UserRole @default(STUDENT)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  profile       Profile?
  screenings    Screening[]
  sessions      Session[]
  notifications Notification[]

  @@index([email])
  @@index([role])
  @@map("users")
}

model Profile {
  id        String   @id @default(uuid())
  userId    String   @unique
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  firstName String
  lastName  String
  phone     String?
  avatar    String?
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("profiles")
}

model Screening {
  id            String    @id @default(uuid())
  userId        String
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  // Scores
  phq9Score     Int       @default(0)
  gad7Score     Int       @default(0)
  totalScore    Int       @default(0)
  riskLevel     RiskLevel @default(LOW)
  
  // Metadata
  completedAt   DateTime  @default(now())
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([userId])
  @@index([riskLevel])
  @@map("screenings")
}

model Session {
  id          String        @id @default(uuid())
  userId      String
  user        User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  title       String
  description String?
  scheduledAt DateTime
  duration    Int           @default(60)
  status      SessionStatus @default(SCHEDULED)
  
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@index([userId])
  @@index([scheduledAt])
  @@map("sessions")
}

model Notification {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  title     String
  message   String
  isRead    Boolean  @default(false)
  
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([isRead])
  @@map("notifications")
}

model SystemSetting {
  id        String   @id @default(uuid())
  key       String   @unique
  value     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("system_settings")
}
